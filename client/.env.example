# Base URL of the backend API server (no trailing slash).
# The client appends /api for REST calls and connects Socket.io to this origin.
VITE_API_URL=http://localhost:4000

# Optional TURN relay for calls that cross strict NAT/firewall networks.
# Separate multiple relay URLs with commas.
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
