# ───────────────────────── Server ─────────────────────────
NODE_ENV=development
PORT=4000
# Public URL where the API is reachable (used to build absolute media URLs)
API_URL=http://localhost:4000
# Comma-separated list of allowed CORS origins (the frontend dev server)
CLIENT_URL=http://localhost:5173

# ──────────────────────── Database ────────────────────────
# Default: file-based SQLite (zero install). Prisma's datasource provider in
# prisma/schema.prisma is set to "sqlite".
DATABASE_URL="file:./dev.db"
# To use PostgreSQL instead, set provider = "postgresql" in schema.prisma and use:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/social_network?schema=public"

# ────────────────────────── Auth ──────────────────────────
# Use long, random strings in production (e.g. `openssl rand -hex 64`)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Google OAuth sign-in. Create credentials in Google Cloud Console and set
# the redirect URI to http://localhost:4000/api/auth/google/callback locally.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ───────────────────────── Uploads ────────────────────────
# Where uploaded media is stored on disk (relative to server root)
UPLOAD_DIR=uploads
# Max upload size in megabytes
MAX_UPLOAD_MB=25
